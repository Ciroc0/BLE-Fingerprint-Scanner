{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "BLE Fingerprint Scanner",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "active": true,
      "identifier": "com.blefingerprintscanner.desktop",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "macOS": {
        "minimumSystemVersion": "12.0"
      },
      "windows": {
        "digestAlgorithm": "sha256"
      }
    },
    "windows": [
      {
        "title": "BLE Fingerprint Scanner",
        "width": 1480,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 720,
        "resizable": true
      }
    ]
  }
}